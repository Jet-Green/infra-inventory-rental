# Скопируйте в .env.frontend в корне infra-inventory-rental.
# Nitro внутри контейнера слушает PORT=3000; снаружи проброшен 3068 (см. docker-compose).

HOST=0.0.0.0
PORT=3000

# Публичный URL API для браузера (хост-машина → опубликованный порт backend).
NUXT_PUBLIC_API_BASE=http://localhost:4000/api
NUXT_PUBLIC_SITE_URL=http://localhost:3068
